{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"check-types": "tsc -b",
		"build": "bun build --target bun --external cpu-features ./src/index.ts --outfile server.js",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run server.js"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"@server-updator/api": "workspace:*",
		"@server-updator/logic": "workspace:*",
		"@server-updator/auth": "workspace:*",
		"@server-updator/db": "workspace:*",
		"@server-updator/env": "workspace:*",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"elysia": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@server-updator/config": "workspace:*",
		"@types/bun": "catalog:",
		"typescript": "catalog:"
	}
}