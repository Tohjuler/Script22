{
	"name": "server",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"check-types": "tsc -b",
		"build": "bun build --target bun --external cpu-features ./src/index.ts --outfile dist/server.js",
		"dev": "bun run --hot src/index.ts",
		"start": "bun run dist/server.js"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@orpc/zod": "catalog:",
		"@script22/api": "workspace:*",
		"@script22/logic": "workspace:*",
		"@script22/auth": "workspace:*",
		"@script22/db": "workspace:*",
		"@script22/env": "workspace:*",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"elysia": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@script22/config": "workspace:*",
		"@types/bun": "catalog:",
		"typescript": "catalog:"
	}
}
