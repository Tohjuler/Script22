{
	"name": "script22",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.3.1",
			"zod": "^4.3.6",
			"typescript": "^5",
			"@types/bun": "^1.3.10",
			"@orpc/server": "^1.13.6",
			"@orpc/openapi": "^1.13.6",
			"@orpc/zod": "^1.13.6",
			"better-auth": "^1.5.4",
			"@libsql/client": "0.17.0",
			"libsql": "0.5.22",
			"@orpc/client": "^1.13.5",
			"elysia": "^1.4.27",
			"drizzle-orm": "^0.45.0",
			"pino": "^10.3.1"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @script22/db db:push",
		"db:studio": "turbo -F @script22/db db:studio",
		"db:generate": "turbo -F @script22/db db:generate",
		"db:migrate": "turbo -F @script22/db db:migrate",
		"db:local": "turbo -F @script22/db db:local",
		"format": "biome check --write .",
		"lint": "biome check . --formatter-enabled=false"
	},
	"dependencies": {
		"@script22/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@script22/config": "workspace:*",
		"@types/bun": "catalog:",
		"turbo": "^2.8.16",
		"typescript": "catalog:"
	},
	"overrides": {
		"cpu-features": "npm:empty-package"
	},
	"packageManager": "bun@1.3.5"
}
